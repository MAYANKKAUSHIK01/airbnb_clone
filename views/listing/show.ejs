<% layout('/layout/boilerplate') %>

<div class="row mt-4">
    <div class="col-8 offset-3">

        <h3 class="mt-3 mb-3"><%= listDetail.title %></h3>

        <div class="card-dl">

            <!-- Image -->
            <img 
                src="<%= listDetail.image.url %>" 
                class="card-img-top rounded-top"
                style="max-height: 300px; width: 50%; object-fit: cover;"
            >

            <div class="card-body">
                <!-- Owner -->
                <p class="card-text mt-3 fs-5">
                   <i>Owned By:  <%= listDetail.owner["username"] %></i>
                </p>
                <!-- Description -->
                <p class="card-text mt-3 fs-5">
                    <%= listDetail.description %>
                </p>

                <!-- Price -->
                <h5 class="text-success mb-3">
                    &#8377;<%= listDetail.price ? listDetail.price.toLocaleString('en-IN') : '0' %>/night
                </h5>

                <!-- Location -->
                <p class="mb-1">
                    <strong><%= listDetail.location %></strong>
                </p>

                <p class="card-text">
                    <%= listDetail.country %>
                </p>



                <% if(currUser&&currUser._id.equals(listDetail.owner._id)){ %>
                <!-- Buttons -->
                <div class="mt-4 d-flex gap-2">

                    <a 
                        class="btn btn-outline-dark add-btn" 
                        href="/listings/<%= listDetail._id %>/edit">
                        Edit
                    </a>

                    <form 
                        class="delete" 
                        method="post" 
                        action="/listings/<%= listDetail._id %>?_method=DELETE"
                    >
                        <button class="btn btn-outline-dark ">
                            Delete
                        </button>
                        <% } %>
                    </form>

                </div>

            </div>
        </div>

    </div>

</div >
<div class="col-8 offset-3 mb-3">
    <% if(currUser){ %>
    <hr>
    <h4>Leave a Review</h4>
    <form action="/listings/<%=listDetail._id%>/reviews" method="post" novalidate class="needs-validation">

<fieldset class="starability-slot mt-3">
  <h5>Rating:</h5>

  <input type="radio" id="no-rate" class="input-no-rate" name="review[rating]" value="1" checked />
  <input type="radio" id="first-rate1" name="review[rating]" value="1" />
  <label for="first-rate1">1 star</label>

  <input type="radio" id="first-rate2" name="review[rating]" value="2" />
  <label for="first-rate2">2 stars</label>

  <input type="radio" id="first-rate3" name="review[rating]" value="3" />
  <label for="first-rate3">3 stars</label>

  <input type="radio" id="first-rate4" name="review[rating]" value="4" />
  <label for="first-rate4">4 stars</label>

  <input type="radio" id="first-rate5" name="review[rating]" value="5" />
  <label for="first-rate5">5 stars</label>
</fieldset>

    <div class="mt-3">
        <label for="comment" class="form-label">comment</label>
        <textarea rows="5" cols="10" name="review[comment]" id="comment" class="form-control" required></textarea>
        <div class="invalid-feedback">Enter Review</div>
    </div>
    <div class="mt-3">
      <button class=" btn btn-outline-dark" >Submit</button>
    </div>
    </form>
    <% } %>
    <hr>
    <p><b>All Reviews</b></p>
    <div class="row mb-3">
    <% for(review of listDetail.reviews){ %>
    <div class="card col-5 ms-3 mt-3  review-card">
        <div class="card-body">
            <h5 class="card-title">@<%=review.author.username%></h5>
             
            <p class="starability-result card-text" data-rating="<%= review.rating %>">
              <h4><p class="card-text"><%= review.comment %></p></h4>
  </p>
        </div>
        <form action="/listings/<%=listDetail._id%>/reviews/<%=review._id%>?_method=DELETE" method="post" class="delete mt-3">
             <button class="btn btn-sm btn-outline-dark">
                            Delete
                        </button>
        </form>
        </div>
    <% } %>
    
    </div>
    


</div>

<script src="/js/delete.js"></script>