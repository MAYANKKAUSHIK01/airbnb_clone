<% layout('/layout/boilerplate') %>

    <div class="row">
        <div class="col-8 offset-2">
            <br><br>
            <h2 class="mb-4">Edit Your Listing</h2>

            <form method="post" action="/listings/<%= listDetail._id %>?_method=PUT" novalidate
                class="needs-validation" enctype="multipart/form-data">

                <div class="mb-3">
                    <label for="title" class="form-label">Title</label>
                    <input name="listing[title]" type="text" class="form-control" id="title"
                        value="<%= listDetail.title %>" required>
                    <div class="valid-feedback">title looks good</div>
                    <div class="invalid-feedback">enter title</div>
                </div>

                <div class="mb-3">
                    <label for="description" class="form-label">Description</label>
                    <textarea name="listing[description]" class="form-control" id="description"
                        required><%= listDetail.description %></textarea>
                    <div class="valid-feedback">description looks good</div>
                    <div class="invalid-feedback">enter description about place</div>
                </div>

<div class="mb-3">
                    <label for="image" class="form-label">Image URL</label>
                    <input name="listing[image]" type="file" placeholder="Image URL/Link" class="form-control"
                        id="image">
                    <div class="valid-feedback">url looks good</div>
                    <div class="invalid-feedback">enter image url</div>
                </div>

                <!-- 🔥 Image Preview -->
                <div class="mb-3 text-center">
                    <img id="previewImg" src="<%= listDetail.image.url %>" class="img-fluid rounded"
                        style="max-height:200px;">
                    <div class="valid-feedback">url looks good</div>
                    <div class="invalid-feedback">enter image url</div>
                </div>

                <div class="row">
                    <div class="mb-3 col-md-4">
                        <label for="price" class="form-label">Price</label>
                        <input name="listing[price]" type="number" class="form-control" id="price"
                            value="<%= listDetail.price %>" required>
                        <div class="valid-feedback">price looks good</div>
                        <div class="invalid-feedback">enter price</div>
                    </div>

                    <div class="mb-3 col-md-8">
                        <label for="country" class="form-label">Country</label>
                        <input name="listing[country]" type="text" class="form-control" id="country"
                            value="<%= listDetail.country %>" required>
                        <div class="valid-feedback">country name</div>
                        <div class="invalid-feedback">enter country name</div>
                    </div>
                </div>

                <div class="mb-3">
                    <label for="location" class="form-label">Location</label>
                    <input name="listing[location]" type="text" class="form-control" id="location"
                        value="<%= listDetail.location %>" required>
                    <div class="valid-feedback">location</div>
                    <div class="invalid-feedback">enter location</div>
                </div>

                <button class="btn add-btn">Update Listing</button>
                <br><br>

            </form>
        </div>
    </div>

    <script src="/js/img.js"></script>
    <script src="/js/validation.js"></script>